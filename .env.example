CURSOR_API_KEY=cursor_...
# Google AI Studio key for Gemini Lookup (free tier + web search grounding)
GEMINI_API_KEY=
# Optional Gemini Lookup depth overrides (Fast / Deep toggle in the app)
# GEMINI_LOOKUP_MODEL_FAST=gemini-2.5-flash
# GEMINI_LOOKUP_MODEL_DEEP=gemini-2.5-flash
# GEMINI_LOOKUP_THINKING_BUDGET_DEEP=-1
SIDECAR_PORT=3847
SIDECAR_TOKEN=dev-token-change-me
NOTES_DIR=
LINEAR_API_KEY=
# Absolute path to Google Cloud OAuth desktop app credentials JSON
GOOGLE_OAUTH_CREDENTIALS=
# Google Calendar account nickname (default: personal)
GOOGLE_CALENDAR_ACCOUNT=personal
# Whoop / Totem MCP tokens — see README (or use ~/.backsteros-agent/totem.env)
# WHOOP_EMAIL=
# WHOOP_IOS_BEARER_TOKEN=
# WHOOP_COGNITO_REFRESH_TOKEN=
