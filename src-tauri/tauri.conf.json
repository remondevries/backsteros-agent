{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BacksterOS Agent",
  "version": "0.1.0",
  "identifier": "com.remondevries.backsteros-agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:all",
    "beforeBuildCommand": "npm run build && npm run build:sidecar"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BacksterOS Agent",
        "width": 960,
        "height": 720,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^((mailto:.+)|(tel:.+)|(https?://.+)|(file://.+)|(linear://.+)|(obsidian://.+))$"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": [
      "resources/sidecar/**/*",
      "resources/tts/**/*",
      "resources/stt/**/*"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
